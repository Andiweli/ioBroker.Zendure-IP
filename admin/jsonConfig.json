{
  "i18n": true,
  "type": "tabs",
  "items": {
    "mainTab": {
      "type": "panel",
      "label": "Einstellungen",
      "items": {
        "devicesInfo": {
          "type": "staticText",
          "text": "Configure up to 10 Zendure devices. The adapter polls http://<ip>/properties/report. Enable 'Device is in HEMS' for devices that should be included in the aggregated HEMS object tree."
        },
        "devices": {
          "newLine": true,
          "type": "table",
          "sm": 12,
          "xs": 12,
          "maxLength": 10,
          "items": [
            {
              "type": "text",
              "attr": "name",
              "title": "Device name",
              "width": "28%"
            },
            {
              "type": "text",
              "attr": "ip",
              "title": "IP address",
              "width": "28%"
            },
            {
              "type": "number",
              "attr": "intervalSec",
              "title": "Interval (s)",
              "min": 1,
              "step": 1,
              "default": 10,
              "width": "18%"
            },
            {
              "type": "checkbox",
              "attr": "isInHems",
              "title": "Device is in HEMS",
              "width": "18%"
            }
          ]
        },
        "note": {
          "newLine": true,
          "type": "staticText",
          "text": "Note: This adapter is read-only. It does not control Zendure devices; it only reads device data and generates daily counters. For full control features, nograx' Zendure adapter is recommended: https://github.com/nograx/ioBroker.zendure-solarflow"
        }
      }
    }
  }
}